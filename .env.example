# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# ── Your OpenAI-compatible backend ────────────────────────────────────────────
CUSTOM_OPENAI_API_BASE=https://your-api.example.com/v1
CUSTOM_OPENAI_API_KEY=your-real-api-key-here

# ── LiteLLM proxy master key (optional) ───────────────────────────────────────
# Uncomment if you want to require an API key for the local proxy.
# Otherwise the proxy accepts all requests (safe when bound to localhost only).
# LITELLM_MASTER_KEY=sk-my-local-proxy-key
